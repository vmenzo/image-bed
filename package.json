{
  "name": "image-bed",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run start:dev -w backend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "lint": "npm run lint -w backend && npm run lint -w frontend",
    "format": "npm run format -w backend && npm run format -w frontend"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "@nestjs/common": {
      ".": "11.1.27",
      "file-type": "21.3.4"
    },
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": {
      ".": "11.1.27",
      "multer": "2.2.0"
    },
    "@nestjs/swagger": {
      ".": "11.4.4",
      "js-yaml": "5.1.0",
      "lodash": "4.18.1"
    },
    "js-yaml": "5.1.0",
    "lodash": "4.18.1",
    "qs": "6.15.3"
  }
}
