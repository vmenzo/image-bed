DATABASE_URL=postgresql://imagebed:imagebed@localhost:5432/imagebed?schema=public
HOST=127.0.0.1
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ALLOW_REGISTER=false
ENABLE_SWAGGER=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
S3_ENDPOINT=http://localhost:9000
S3_UPLOAD_ENDPOINT=/image-bed
S3_REGION=us-east-1
S3_BUCKET=image-bed
S3_ACCESS_KEY=replace-with-s3-access-key
S3_SECRET_KEY=replace-with-s3-secret-key
S3_FORCE_PATH_STYLE=true
PUBLIC_IMAGE_BASE_URL=/image-bed
CORS_ORIGIN=http://localhost:7899,http://127.0.0.1:7899
